// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum CyclePhase {
  GOAL_SETTING
  Q1
  Q2
  Q3
  Q4
}

enum UomType {
  NUMERIC_MIN
  NUMERIC_MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RETURNED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum ProgressStatus {
  NOT_STARTED
  ON_TRACK
  AT_RISK
  COMPLETED
}

enum EscalationTrigger {
  GOAL_NOT_SUBMITTED
  GOAL_NOT_APPROVED
  CHECKIN_NOT_COMPLETED
}

enum EscalationStatus {
  PENDING
  NOTIFIED
  ESCALATED
  RESOLVED
}

enum NotificationType {
  EMAIL
  TEAMS
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  managerId    String?
  manager      User?    @relation("UserManager", fields: [managerId], references: [id])
  reports      User[]   @relation("UserManager")
  department   String
  isActive     Boolean  @default(true)
  azureOid     String?  @unique  // Microsoft Entra ID Object ID for SSO
  createdAt    DateTime @default(now())

  // Reverse relations
  goals           Goal[]           @relation("EmployeeGoals")
  checkinComments CheckinComment[] @relation("ManagerComments")
  auditLogs       AuditLog[]       @relation("AuditUser")
  sharedGoals     SharedGoalRecipient[] @relation("RecipientUser")
  notifications   NotificationLog[]    @relation("NotificationUser")
  escalationLogs  EscalationLog[]      @relation("EscalationUser")

  @@map("users")
}

model GoalCycle {
  id        String     @id @default(uuid())
  name      String
  phase     CyclePhase
  year      Int
  opensAt   DateTime
  closesAt  DateTime
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())

  goals           Goal[]           @relation("CycleGoals")
  escalationRules EscalationRule[] @relation("CycleEscalationRules")

  @@map("goal_cycles")
}

model Goal {
  id           String     @id @default(uuid())
  employeeId   String
  employee     User       @relation("EmployeeGoals", fields: [employeeId], references: [id])
  cycleId      String
  cycle        GoalCycle  @relation("CycleGoals", fields: [cycleId], references: [id])
  thrustArea   String
  title        String
  description  String
  uomType      UomType
  targetValue  Float?
  targetDate   DateTime?
  weightage    Float
  status       GoalStatus @default(DRAFT)
  isShared     Boolean    @default(false)
  parentGoalId String?
  parentGoal   Goal?      @relation("SharedGoalTree", fields: [parentGoalId], references: [id])
  childGoals   Goal[]     @relation("SharedGoalTree")
  lockedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Reverse relations
  achievements GoalAchievement[] @relation("GoalAchievements")
  comments     CheckinComment[]  @relation("GoalComments")
  recipients   SharedGoalRecipient[] @relation("SharedGoalParent")

  @@map("goals")
}

model GoalAchievement {
  id             String         @id @default(uuid())
  goalId         String
  goal           Goal           @relation("GoalAchievements", fields: [goalId], references: [id])
  quarter        Quarter
  actualValue    Float?
  actualDate     DateTime?
  progressStatus ProgressStatus @default(NOT_STARTED)
  computedScore  Float?
  updatedAt      DateTime       @updatedAt

  @@map("goal_achievements")
}

model CheckinComment {
  id        String   @id @default(uuid())
  goalId    String
  goal      Goal     @relation("GoalComments", fields: [goalId], references: [id])
  managerId String
  manager   User     @relation("ManagerComments", fields: [managerId], references: [id])
  quarter   Quarter
  comment   String
  createdAt DateTime @default(now())

  @@map("checkin_comments")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  changedBy  String
  changedByUser User @relation("AuditUser", fields: [changedBy], references: [id])
  oldValue   Json
  newValue   Json
  changedAt  DateTime @default(now())

  @@map("audit_logs")
}

model SharedGoalRecipient {
  id             String @id @default(uuid())
  parentGoalId   String
  parentGoal     Goal   @relation("SharedGoalParent", fields: [parentGoalId], references: [id])
  recipientId    String
  recipient      User   @relation("RecipientUser", fields: [recipientId], references: [id])
  customWeightage Float

  @@map("shared_goal_recipients")
}

// ─── Bonus: Escalation Module ───────────────────────────────────────────────

model EscalationRule {
  id            String            @id @default(uuid())
  cycleId       String
  cycle         GoalCycle         @relation("CycleEscalationRules", fields: [cycleId], references: [id])
  trigger       EscalationTrigger
  thresholdDays Int               // Days after which to escalate
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())

  logs EscalationLog[] @relation("RuleEscalationLogs")

  @@map("escalation_rules")
}

model EscalationLog {
  id         String           @id @default(uuid())
  ruleId     String
  rule       EscalationRule   @relation("RuleEscalationLogs", fields: [ruleId], references: [id])
  userId     String
  user       User             @relation("EscalationUser", fields: [userId], references: [id])
  status     EscalationStatus @default(PENDING)
  level      Int              @default(1) // 1=employee, 2=manager, 3=skip-level/HR
  message    String
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@map("escalation_logs")
}

// ─── Bonus: Notification Module ─────────────────────────────────────────────

model NotificationLog {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("NotificationUser", fields: [userId], references: [id])
  type      NotificationType
  event     String           // e.g. GOAL_SUBMITTED, GOAL_APPROVED, CHECKIN_REMINDER
  subject   String
  body      String
  metadata  Json?            // deep-link URL, Teams card payload, etc.
  sentAt    DateTime         @default(now())
  success   Boolean          @default(true)

  @@map("notification_logs")
}
