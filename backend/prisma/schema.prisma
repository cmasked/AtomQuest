// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum CyclePhase {
  GOAL_SETTING
  Q1
  Q2
  Q3
  Q4
}

enum UomType {
  NUMERIC_MIN
  NUMERIC_MAX
  TIMELINE
  ZERO
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RETURNED
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum ProgressStatus {
  NOT_STARTED
  ON_TRACK
  COMPLETED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  managerId    String?
  manager      User?    @relation("UserManager", fields: [managerId], references: [id])
  reports      User[]   @relation("UserManager")
  department   String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Reverse relations
  goals           Goal[]           @relation("EmployeeGoals")
  checkinComments CheckinComment[] @relation("ManagerComments")
  auditLogs       AuditLog[]       @relation("AuditUser")
  sharedGoals     SharedGoalRecipient[] @relation("RecipientUser")

  @@map("users")
}

model GoalCycle {
  id        String     @id @default(uuid())
  name      String
  phase     CyclePhase
  year      Int
  opensAt   DateTime
  closesAt  DateTime
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())

  goals Goal[] @relation("CycleGoals")

  @@map("goal_cycles")
}

model Goal {
  id           String     @id @default(uuid())
  employeeId   String
  employee     User       @relation("EmployeeGoals", fields: [employeeId], references: [id])
  cycleId      String
  cycle        GoalCycle  @relation("CycleGoals", fields: [cycleId], references: [id])
  thrustArea   String
  title        String
  description  String
  uomType      UomType
  targetValue  Float?
  targetDate   DateTime?
  weightage    Float
  status       GoalStatus @default(DRAFT)
  isShared     Boolean    @default(false)
  parentGoalId String?
  parentGoal   Goal?      @relation("SharedGoalTree", fields: [parentGoalId], references: [id])
  childGoals   Goal[]     @relation("SharedGoalTree")
  lockedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Reverse relations
  achievements GoalAchievement[] @relation("GoalAchievements")
  comments     CheckinComment[]  @relation("GoalComments")
  recipients   SharedGoalRecipient[] @relation("SharedGoalParent")

  @@map("goals")
}

model GoalAchievement {
  id             String         @id @default(uuid())
  goalId         String
  goal           Goal           @relation("GoalAchievements", fields: [goalId], references: [id])
  quarter        Quarter
  actualValue    Float?
  actualDate     DateTime?
  progressStatus ProgressStatus @default(NOT_STARTED)
  computedScore  Float?
  updatedAt      DateTime       @updatedAt

  @@map("goal_achievements")
}

model CheckinComment {
  id        String   @id @default(uuid())
  goalId    String
  goal      Goal     @relation("GoalComments", fields: [goalId], references: [id])
  managerId String
  manager   User     @relation("ManagerComments", fields: [managerId], references: [id])
  quarter   Quarter
  comment   String
  createdAt DateTime @default(now())

  @@map("checkin_comments")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  changedBy  String
  changedByUser User @relation("AuditUser", fields: [changedBy], references: [id])
  oldValue   Json
  newValue   Json
  changedAt  DateTime @default(now())

  @@map("audit_logs")
}

model SharedGoalRecipient {
  id             String @id @default(uuid())
  parentGoalId   String
  parentGoal     Goal   @relation("SharedGoalParent", fields: [parentGoalId], references: [id])
  recipientId    String
  recipient      User   @relation("RecipientUser", fields: [recipientId], references: [id])
  customWeightage Float

  @@map("shared_goal_recipients")
}
